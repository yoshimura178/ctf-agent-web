# Directory containing local task folders.
# Expected layout: task/<challenge>/README.md plus any attached challenge files.
TASKS_DIR=task

# Runtime directory generated by the agent.
# Each task is normalized here as metadata.yml + distfiles/ for Docker mounting.
LOCAL_CHALLENGES_DIR=challenges-local

# Browser user-data-dir already logged into ChatGPT
# Example Chrome path on Windows:
# WEBCHAT_BROWSER_USER_DATA_DIR=C:\Users\<you>\AppData\Local\Google\Chrome\User Data
WEBCHAT_BROWSER_USER_DATA_DIR=

# Browser profile under the user-data-dir.
# Common values: Default, Profile 1, Profile 2.
WEBCHAT_BROWSER_PROFILE=Default

# Headless browser mode.
# Keep false until DOM selectors and file upload are stable.
WEBCHAT_HEADLESS=false

# Max chat/tool actions per solver run before the swarm can bump/retry it.
WEBCHAT_MAX_STEPS_PER_RUN=25


# Terminal display mode.
# false: normal Rich terminal UI with compact panels/tables.
# true: debug mode with verbose logs. The CLI -v flag also enables debug mode.
TERMINAL_DEBUG=false

# Enable ChatGPT web solver profile for o3 with Medium intelligence.
ENABLE_CHATGPT_O3_MEDIUM=true

# Enable ChatGPT web solver profile for GPT-5.5 with High intelligence.
ENABLE_CHATGPT_GPT55_HIGH=true

# Enable ChatGPT web solver profile for GPT-5.4 with High intelligence.
ENABLE_CHATGPT_GPT54_HIGH=true

# Docker image used for each solver sandbox.
SANDBOX_IMAGE=ctf-sandbox

# Max tasks/challenges solved in parallel.
# Total Docker containers ~= MAX_CONCURRENT_CHALLENGES * enabled model count.
MAX_CONCURRENT_CHALLENGES=1

# Memory limit per solver Docker container.
# Examples: 4g, 8192m, 17179869184.
CONTAINER_MEMORY_LIMIT=16g

# CPU limit per solver Docker container.
# Supports fractional values: 0.5, 1.0, 2.0.
CONTAINER_CPU_LIMIT=2.0
